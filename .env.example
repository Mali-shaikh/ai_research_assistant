APP_NAME=AI Academic Research Assistant
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
DEBUG=true

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini

DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/research_db

JWT_SECRET_KEY=change_this_secret_key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

MAX_UPLOAD_MB=15
ALLOWED_EXTENSIONS=.pdf,.txt,.md,.docx
CORS_ORIGINS=*
